<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.activity.PlayerActivity">

    <include layout="@layout/tab_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_lg">

            <ImageView
                android:id="@+id/player_album_art"
                android:layout_width="@dimen/album_art_size"
                android:layout_height="@dimen/album_art_size"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground"
                android:background="@drawable/album_art_background"
                android:elevation="8dp"
                android:clipToOutline="true"
                android:outlineProvider="background" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_lg">

                <TextView
                    android:id="@+id/player_song_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="歌曲标题"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/T1"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:letterSpacing="0.01" />

                <TextView
                    android:id="@+id/player_song_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="歌手"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/T2"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

            <com.example.catmusic.lyric.LyricView
                android:id="@+id/lyric_view"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/lyric_background"
                android:padding="@dimen/spacing_md" />

            <TextView
                android:id="@+id/no_lyric_text"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/lyric_background"
                android:padding="@dimen/spacing_md"
                android:text="暂无歌词"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/T2"
                android:gravity="center"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl"
        android:background="@drawable/player_control_background"
        android:elevation="8dp"
        android:layout_margin="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:id="@+id/player_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="@dimen/caption"
                android:textColor="@color/text_secondary"
                android:minWidth="36dp" />

            <SeekBar
                android:id="@+id/player_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <TextView
                android:id="@+id/player_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="@dimen/caption"
                android:textColor="@color/text_secondary"
                android:minWidth="36dp"
                android:gravity="end" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="@dimen/spacing_sm">

            <ImageView
                android:id="@+id/btn_repeat"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/loop_active"
                android:contentDescription="@null"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btn_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/pre_active"
                android:contentDescription="@null"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btn_play_pause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/play_active"
                android:contentDescription="@null"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btn_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/next_active"
                android:contentDescription="@null"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btn_shuffle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/random_active"
                android:contentDescription="@null"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btn_playlist"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:padding="@dimen/spacing_sm"
                android:contentDescription="@string/playlist"
                android:src="@drawable/ic_playlist"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btn_favorite"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="@dimen/spacing_xs"
                android:padding="@dimen/spacing_sm"
                android:contentDescription="@string/desc_favorite"
                android:src="@drawable/ic_favorite_border"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
